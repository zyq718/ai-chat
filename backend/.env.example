# ===== Flask 配置 =====
SECRET_KEY=ai-chat-dev-secret-change-in-prod
FLASK_ENV=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== AI 大模型配置 =====
# 可选：mock | deepseek | doubao | qwen | qclaw | openai | custom
AI_PROVIDER=mock

# DeepSeek（推荐：性价比高，中文优秀）
# 获取：https://platform.deepseek.com/api_keys
# AI_PROVIDER=deepseek
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# 豆包 / 火山方舟（字节跳动）
# 获取：https://www.volcengine.com/product/doubao
# AI_PROVIDER=doubao
# AI_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# AI_MODEL=doubao-pro-32k

# 通义千问（阿里云 DashScope）
# 获取：https://dashscope.console.aliyun.com/apiKey
# AI_PROVIDER=qwen
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-plus

# QClaw（自定义 OpenAI 兼容端点）
# AI_PROVIDER=qclaw
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://api.qclaw.ai/v1
# AI_MODEL=qclaw-pro
# QCLAW_BASE_URL=https://api.qclaw.ai/v1
# QCLAW_MODEL=qclaw-pro

# OpenAI 官方
# AI_PROVIDER=openai
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://api.openai.com
# AI_MODEL=gpt-4o-mini

# 自定义 OpenAI 兼容端点（如 Ollama/vLLM/FastChat）
# AI_PROVIDER=custom
# AI_API_KEY=EMPTY
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=qwen2.5:7b
# CUSTOM_BASE_URL=http://localhost:11434/v1
# CUSTOM_MODEL=qwen2.5:7b

# ===== 数据库 =====
DATABASE_URL=sqlite:///chat.db
